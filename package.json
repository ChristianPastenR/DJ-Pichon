{
  "name": "discord-youtube-music-bot",
  "version": "1.0.0",
  "private": true,
  "description": "Bot de musica para Discord con busqueda en YouTube y cola por servidor.",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "lint": "eslint .",
    "format": "prettier --check .",
    "format:write": "prettier --write ."
  },
  "engines": {
    "node": ">=22.13.0"
  },
  "dependencies": {
    "@discordjs/voice": "0.19.2",
    "discord.js": "14.26.4",
    "dotenv": "17.4.2",
    "ffmpeg-static": "5.3.0",
    "youtube-dl-exec": "3.1.7"
  },
  "devDependencies": {
    "eslint": "10.5.0",
    "prettier": "3.8.4"
  }
}
