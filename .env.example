DISCORD_TOKEN=pega_aqui_el_token_del_bot
COMMAND_PREFIX=!

# Limita el bot a un canal de texto concreto.
# DISCORD_CHANNEL_ID=123456789012345678

# Opcional: limita el registro de comandos slash a este servidor.
# Sin este valor se registran en todos los servidores donde ya esta el bot.
# DISCORD_GUILD_ID=123456789012345678

MAX_QUEUE_SIZE=100
SELECTION_TIMEOUT_SECONDS=90
IDLE_TIMEOUT_SECONDS=300
LOG_LEVEL=info
